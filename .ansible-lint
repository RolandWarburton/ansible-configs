---
# https://ansible.readthedocs.io/projects/lint/configuring/
#
# Strategy: enforce YAML formatting + schema/syntax as errors (they block a
# commit), and downgrade the style/idiom/command-shell rules to warnings
# (shown but non-blocking). Tighten by moving rules out of warn_list later.
exclude_paths:
  - .git/
  - .cache/
  # Roles are commented out in its resting state, so `roles:` is None and
  # trips the non-skippable schema[playbook] rule. Uncomment roles to run it.
  - playbooks/setup-localhost.yml

# Enforced as errors (NOT listed below): yaml, key-order, schema, syntax-check,
# name (task/handler/play names: present + capitalised, no mid-name templates),
# partial-become (become_user must be paired with become at the same level),
# literal-compare (no `when: x == true`),
# no-changed-when (command/shell tasks must declare changed_when),
# risky-file-permissions (files/dirs need an explicit mode),
# ignore-errors (use failed_when instead),
# no-handler (use notify + a handler, not `when: x.changed`),
# command-instead-of-shell (use shell only for pipes/redirects/expansion),
# var-naming (role vars must be prefixed with the role name),
# latest (git clones must pin a version).

# Shown as warnings, do not block a commit:
warn_list:
  - command-instead-of-module # intentional curl/shell installs
  - risky-shell-pipe # `curl ... | sh` style installs

# Repo intentionally uses short module names (apt, copy) not ansible.builtin.*
skip_list:
  - fqcn
  - yaml[document-start] # repo does not use the leading '---' marker
  # Role dirs are named with dashes (xray-client, ntfy-cli, sway-fonts) and
  # playbooks reference roles by path (./roles/rust) rather than via a
  # configured roles_path. Both are deliberate; renaming would churn every
  # playbook and host_vars entry for no functional gain.
  - role-name
